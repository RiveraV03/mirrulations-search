[Unit]
Description=Mirrulations Download Reaper (one-shot cleanup)
After=network.target postgresql.service

[Service]
Type=oneshot
User=ec2-user
WorkingDirectory=/home/ec2-user/mirrulations-search

EnvironmentFile=-/home/ec2-user/mirrulations-search/.env

ExecStart=/home/ec2-user/mirrulations-search/.venv/bin/python /home/ec2-user/mirrulations-search/reaper.py

StandardOutput=journal
StandardError=journal
SyslogIdentifier=mirrulations-reaper
